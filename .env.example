# Entorno: development | production
ENV=development

# Neon Postgres — usar el host "-pooler" para la app (async, asyncpg)
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/dbname?ssl=require

# Neon Postgres — host directo, sin pooler (usado solo por Alembic, driver sync)
DATABASE_URL_DIRECT=postgresql+psycopg2://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require

# Secreto usado para firmar tokens CSRF y otros propósitos internos.
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(64))"
SESSION_SECRET=

# Nombre de la cookie de sesión
SESSION_COOKIE_NAME=clara_session

# Duración de la sesión en minutos
SESSION_LIFETIME_MINUTES=720

# Gmail SMTP — recomendado (gratis, sin dominio propio)
# 1. Activa verificación en 2 pasos en tu cuenta Gmail
# 2. Ve a: myaccount.google.com/apppasswords
# 3. Crea una App Password con nombre "Clara Certificados"
# 4. Pega los 16 caracteres en SMTP_PASSWORD (sin espacios)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-correo@gmail.com
SMTP_PASSWORD=abcdabcdabcdabcd

# Resend (opcional, se usa si SMTP_USER/SMTP_PASSWORD no están configurados)
RESEND_API_KEY=
EMAIL_FROM="Clara Certificados <certificados@tu-dominio.com>"

# Datos para el script de bootstrap del primer Admin (scripts/seed_admin.py)
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_FULL_NAME=
